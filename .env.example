# ====================================================
# INVOICES CRONJOB - UMGEBUNGSVARIABLEN
# ====================================================
# Nach .env kopieren und mit echten Werten füllen
# .env NICHT in die Versionsverwaltung einchecken!

# ====================================================
# D.VELOP-CLOUD-KONFIGURATION
# ====================================================
DVELOP_API_KEY=your_api_key_here
DVELOP_SCRIPT_URL=https://your-instance.d-velop.cloud/scripting/script/xxx/run
DVELOP_BASE_URL=https://your-instance.d-velop.cloud
DVELOP_REPO_ID=your_repo_id_here

# ====================================================
# SMTP-RELAY-KONFIGURATION
# ====================================================
# Für lokale Entwicklung (Mailhog/MailCatcher):
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false

# Für den Produktivbetrieb (echter SMTP-Server):
SMTP_HOST=mail.ft-immobilien.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=your_username
SMTP_PASS=your_password
SMTP_FROM=sender@ft-immobilien.com

# ====================================================
# WEB-UI-KONFIGURATION
# ====================================================
UI_ENABLED=true
UI_HOST=0.0.0.0
UI_PORT=3030

# ====================================================
# OPTIONALE EINSTELLUNGEN
# ====================================================
# Speicherort der benutzerdefinierten Einstellungsdatei (Standard: config/app-settings.json)
SETTINGS_FILE_PATH=/opt/invoices_cronjob/config/app-settings.json

# Maximale Anhangsgröße in Bytes (Standard: ca. 3 MB)
# MAX_ATTACHMENT_BYTES=25000000

# Temporäres Verzeichnis für PDFs (Standard: /tmp/invoices_cronjob)
TEMP_DIR=/tmp/invoices_cronjob

# Temporäre Dateien für Debugging behalten (Standard: false)
KEEP_TEMP_FILES=false

# Zeitzone für Cron-Ausdrücke (Standard: Europe/Berlin)
# CRON_TIMEZONE=Europe/Berlin

